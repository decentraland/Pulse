{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Transport": {
    "PeerTimeoutMs": 300000,
    "Hardening": {
      "PreAuth": {
        "PreAuthBudget": 0,
        "MaxConcurrentPreAuthPerIP": 0
      }
    }
  },
  "Messaging": {
    "Hardening": {
      "Handshake": {
        "MaxAttempts": 2
      },
      "MovementInput": {
        "MaxHz": 20,
        "BurstCapacity": 16
      },
      "DiscreteEvent": {
        "RatePerSecond": 5.0,
        "BurstCapacity": 10
      },
      "FieldValidator": {
        "MaxEmoteIdLength": 64,
        "MaxRealmLength": 128,
        "MaxEmoteDurationMs": 60000
      },
      "HandshakeReplay": {
        "Enabled": true
      },
      "Bans": {
        "PollIntervalSeconds": 30,
        "HttpTimeoutSeconds": 10
      }
    }
  },
  "Peers": {
    "SelfMirrorEnabled": false,
    "SelfMirrorTier": 0,
    "MaxWorkerThreads": 4
  },
  "Metrics": {
    "Type": "Console"
  }
}
