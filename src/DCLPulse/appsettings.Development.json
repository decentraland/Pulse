{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Transport": {
    "PeerTimeoutMs": 300000,
    "Hardening": {
      "PreAuth": {
        "PreAuthBudget": 512,
        "MaxConcurrentPreAuthPerIP": 32
      },
      "CorruptedPacket": {
        "MaxPerMinute": 5,
        "BurstCapacity": 5
      }
    }
  },
  "Messaging": {
    "Hardening": {
      "Handshake": {
        "MaxAttempts": 2
      },
      "MovementInput": {
        "MaxHz": 20,
        "BurstCapacity": 16
      },
      "DiscreteEvent": {
        "RatePerSecond": 20,
        "BurstCapacity": 16
      },
      "FieldValidator": {
        "MaxRealmLength": 255,
        "MaxEmoteDurationMs": 60000
      },
      "HandshakeReplay": {
        "Enabled": true
      },
      "Bans": {
        "PollIntervalSeconds": 30,
        "HttpTimeoutSeconds": 10
      }
    }
  },
  "SceneListener": {
    "MaxParcels": 4096
  },
  "Peers": {
    "SelfMirrorEnabled": false,
    "SelfMirrorTier": 0,
    "MaxWorkerThreads": 4
  },
  "Metrics": {
    "Type": "Console"
  }
}
