FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /build
COPY ["src/DCLPulse/DCLPulse.csproj", "src/DCLPulse/"]
COPY ["src/DCLPulse/global.json", "src/DCLPulse/"]
COPY ["src/DCLAuth/DCLAuth.csproj", "src/DCLAuth/"]
COPY ["src/Protocol/Protocol.csproj", "src/Protocol/"]
COPY ["src/Protocol/Directory.Build.props", "src/Protocol/"]
RUN dotnet restore "src/DCLPulse/DCLPulse.csproj"
COPY src/ src/
WORKDIR "/build/src/DCLPulse"
RUN dotnet publish "DCLPulse.csproj" -c Debug -o /app/publish /p:UseAppHost=false /p:GenerateProto=false

FROM mcr.microsoft.com/dotnet/runtime:10.0 AS final
ARG COMMIT_HASH=unknown
ENV COMMIT_HASH=$COMMIT_HASH
RUN apt-get update && apt-get install -y --no-install-recommends curl unzip procps openssh-server \
    && curl -sSL https://aka.ms/getvsdbgsh | bash /dev/stdin -v latest -l /vsdbg \
    && RRD_URL=$(curl -sSIL -o /dev/null -w '%{url_effective}' "https://data.services.jetbrains.com/products/download?code=RRD&platform=linux64") \
    && RRD_VERSION=$(echo "$RRD_URL" | sed 's/.*linux-x64\.\(.*\)\.zip/\1/') \
    && curl -sSL -o /tmp/rrd.zip "$RRD_URL" \
    && mkdir -p "/root/.local/share/JetBrains/RiderRemoteDebugger/${RRD_VERSION}" \
    && unzip -oq /tmp/rrd.zip -d "/root/.local/share/JetBrains/RiderRemoteDebugger/${RRD_VERSION}" \
    && rm /tmp/rrd.zip \
    && apt-get remove -y curl unzip && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir /run/sshd \
    && ssh-keygen -A \
    && passwd -d root \
    && printf 'Port 2222\nPermitRootLogin yes\nPermitEmptyPasswords yes\n' > /etc/ssh/sshd_config.d/debug.conf
WORKDIR /app
COPY --from=build /app/publish .
EXPOSE 7777/udp
EXPOSE 2222/tcp
ENTRYPOINT ["/bin/sh", "-c", "set -e && /usr/sbin/sshd && exec dotnet DCLPulse.dll"]
