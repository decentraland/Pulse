{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },
  "Transport": {
    "Port": 7777,
    "MaxPeers": 4095,
    "MaxConcurrentConnections": 0,
    "ServiceTimeoutMs": 1000,
    "BufferSize": 4096,
    "Hardening": {
      "PreAuth": {
        "PreAuthBudget": 512,
        "MaxConcurrentPreAuthPerIP": 32
      }
    }
  },
  "Messaging": {
    "Hardening": {
      "Handshake": {
        "MaxAttempts": 2
      },
      "MovementInput": {
        "MaxHz": 20
      },
      "DiscreteEvent": {
        "RatePerSecond": 5.0,
        "BurstCapacity": 10
      },
      "FieldValidator": {
        "MaxEmoteIdLength": 64,
        "MaxRealmLength": 128,
        "MaxEmoteDurationMs": 60000
      },
      "HandshakeReplay": {
        "Enabled": true
      }
    }
  },
  "Peers": {
    "SnapshotHistoryCapacity": 20,
    "SimulationSteps": [50, 100, 200],
    "SelfMirrorEnabled": false,
    "SelfMirrorTier": 0,
    "DisconnectionCleanTimeoutMs": 5000,
    "PendingAuthCleanTimeoutMs": 30000
  },
  "SpatialAreaOfInterest": {
    "Tier0Radius": 20,
    "Tier1Radius": 50,
    "MaxRadius": 100
  },
  "SpatialHashAreaOfInterest": {
    "Tier0Radius": 20,
    "Tier1Radius": 50,
    "MaxRadius": 100,
    "CellSize": 50
  },
  "ParcelEncoder": {
    "MinParcelX": -150,
    "MinParcelZ":-150,
    "MaxParcelX": 163,
    "MaxParcelZ": 158,
    "Padding": 2,
    "ParcelSize": 16
  },
  "Metrics": {
    "Type": "Prometheus"
  },
  "HttpService": {
    "Port": 5000
  }
}
