{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },
  "Transport": {
    "BindHost": "0.0.0.0",
    "Port": 7777,
    "MaxPeers": 4095,
    "MaxConcurrentConnections": 0,
    "ServiceTimeoutMs": 1000,
    "BufferSize": 4096,
    "Hardening": {
      "PreAuth": {
        "PreAuthBudget": 512,
        "MaxConcurrentPreAuthPerIP": 32
      },
      "CorruptedPacket": {
        "MaxPerMinute": 5,
        "BurstCapacity": 5
      }
    }
  },
  "WebTransport": {
    "Enabled": false,
    "BindHost": "0.0.0.0",
    "Port": 7443,
    "MaxDatagramBytes": 1200,
    "MaxMessageBytes": 4096
  },
  "Messaging": {
    "Hardening": {
      "Handshake": {
        "MaxAttempts": 2
      },
      "MovementInput": {
        "MaxHz": 20,
        "BurstCapacity": 16
      },
      "DiscreteEvent": {
        "RatePerSecond": 20,
        "BurstCapacity": 16
      },
      "FieldValidator": {
        "MaxRealmLength": 255,
        "MaxEmoteDurationMs": 60000
      },
      "HandshakeReplay": {
        "Enabled": true
      },
      "Bans": {
        "PollIntervalSeconds": 30,
        "HttpTimeoutSeconds": 10
      }
    }
  },
  "Peers": {
    "SnapshotHistoryCapacity": 20,
    "SimulationSteps": [50, 100, 200],
    "SelfMirrorEnabled": false,
    "SelfMirrorTier": 0,
    "DisconnectionCleanTimeoutMs": 5000,
    "PendingAuthCleanTimeoutMs": 30000
  },
  "SpatialAreaOfInterest": {
    "Tier0Radius": 20,
    "Tier1Radius": 50,
    "MaxRadius": 100
  },
  "SpatialHashAreaOfInterest": {
    "Tier0Radius": 30,
    "Tier1Radius": 60,
    "MaxRadius": 200,
    "CellSize": 100,
    "ScanCellRadius": 2
  },
  "ParcelEncoder": {
    "MinParcelX": -150,
    "MinParcelZ":-150,
    "MaxParcelX": 163,
    "MaxParcelZ": 158,
    "Padding": 2,
    "ParcelSize": 16
  },
  "Metrics": {
    "Type": "Prometheus"
  },
  "HttpService": {
    "Port": 5000
  }
}
