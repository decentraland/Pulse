{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Transport": {
    "PeerTimeoutMs": 300000,
    "Hardening": {
      "PreAuth": {
        "PreAuthBudget": 0,
        "MaxConcurrentPreAuthPerIP": 0
      }
    }
  },
  "Messaging": {
    "Hardening": {
      "Handshake": {
        "MaxAttempts": 0
      }
    }
  },
  "Peers": {
    "SelfMirrorEnabled": false,
    "SelfMirrorTier": 0,
    "MaxWorkerThreads": 4
  },
  "Metrics": {
    "Type": "Console"
  }
}
